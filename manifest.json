{
  "manifest_version": 3,
  "name": "Web Highlighter",
  "version": "1.0.1",
  "description": "Highlight text on web pages with multiple colors. Highlights persist across sessions and sync between Chrome and Edge.",
  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["highlighter.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "highlight-yellow": {
      "suggested_key": {
        "default": "Ctrl+Shift+H"
      },
      "description": "Highlight with yellow"
    },
    "highlight-green": {
      "suggested_key": {
        "default": "Ctrl+Shift+G"
      },
      "description": "Highlight with green"
    },
    "highlight-blue": {
      "suggested_key": {
        "default": "Ctrl+Shift+B"
      },
      "description": "Highlight with blue"
    },
    "remove-highlight": {
      "suggested_key": {
        "default": "Ctrl+Shift+R"
      },
      "description": "Remove highlight"
    }
  }
}
